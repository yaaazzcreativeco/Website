{% set nav = settings.nav_items or [
  { href: "/shop/", label: "Shop", id: "shop" },
  { href: "/devotionals/", label: "Devotionals", id: "devotionals" },
  { href: "/journaling-tips/", label: "Club Hub", id: "journal" },
  { href: "/our-story/", label: "Our Story", id: "story" },
  { href: "/contact/", label: "Contact", id: "contact" }
] %}
<header class="fixed top-0 z-50 w-full bg-[#fcf6e3]/80 backdrop-blur-xl shadow-[0_10px_30px_rgba(49,47,35,0.06)]">
  <nav class="flex justify-between items-center w-full px-6 py-2 max-w-7xl mx-auto" aria-label="Primary">
    <div class="flex items-center gap-4">
      <a
        class="logo-link logo-link--header group inline-flex shrink-0 items-center justify-center overflow-visible outline-none transition-transform duration-300 focus-visible:ring-2 focus-visible:ring-primary/35 focus-visible:ring-offset-2 focus-visible:ring-offset-[#fcf6e3]"
        href="{{ '/' | url }}"
      >
        {% logo settings.logo_url, (settings.site_name | default('Yaaazz Creative Co.')) + " Logo", 200, "logo-mark h-20 md:h-24 w-auto max-w-[200px] md:max-w-[240px] shadow-none object-contain object-center transition-all duration-300 ease-out" %}
      </a>
    </div>
    <div class="hidden md:flex items-center gap-8 font-headline font-bold text-lg tracking-tight">
        {% for item in nav %}
          <a
            class="text-[#7d4d5f]{% if activeNav and activeNav == item.id %} border-b-4 border-[#b2f2bb] pb-1 rotate-3{% else %}/70 hover:text-[#7d4d5f]{% endif %} transition-all hover:scale-105 hover:rotate-3"
            href="{{ item | resolveNav(categoryList) | sitePath | url }}"
          >{{ item.label }}</a>
        {% endfor %}
    </div>
    <div class="flex items-center gap-3">
      <a href="{{ '/checkout/' | url }}" class="relative p-2 text-[#7d4d5f] hover:scale-110 transition-transform active:scale-95" aria-label="Cart and checkout">
        <span class="material-symbols-outlined text-2xl">shopping_bag</span>
        <span id="cart-badge" class="absolute -top-0.5 -right-0.5 min-w-[1.25rem] h-5 px-1 rounded-full bg-secondary text-on-secondary text-[10px] font-bold flex items-center justify-center hidden" aria-hidden="true">0</span>
      </a>
      <button id="mobile-menu-btn" class="md:hidden relative p-2 text-[#7d4d5f] hover:scale-110 transition-transform active:scale-95 border-none bg-transparent cursor-pointer" aria-label="Toggle menu" aria-expanded="false">
        <span class="material-symbols-outlined text-2xl block" id="menu-icon">menu</span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden md:hidden absolute top-full left-0 w-full bg-[#fcf6e3]/95 backdrop-blur-xl border-t border-[#e3ddc5] shadow-lg origin-top transition-all duration-300">
    <nav class="flex flex-col px-6 py-4 font-headline font-bold text-lg" aria-label="Mobile">
      {% for item in nav %}
        <a class="py-3 border-b border-[#e3ddc5]/50 text-[#7d4d5f] hover:pl-2 transition-all{% if activeNav and activeNav == item.id %} text-[#2c673c] bg-secondary-container/20{% endif %}" href="{{ item | resolveNav(categoryList) | sitePath | url }}">
          {{ item.label }}
        </a>
      {% endfor %}
    </nav>
  </div>
</header>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const icon = document.getElementById('menu-icon');
    
    if (btn && menu) {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        if (expanded) {
          btn.setAttribute('aria-expanded', 'false');
          menu.classList.add('hidden');
          icon.textContent = 'menu';
        } else {
          btn.setAttribute('aria-expanded', 'true');
          menu.classList.remove('hidden');
          icon.textContent = 'close';
        }
      });
    }
  });
</script>
<div class="h-24 md:h-28" aria-hidden="true"></div>
