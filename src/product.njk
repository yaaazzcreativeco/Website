</section>

<script>
  let qty = 1;
  function changeQty(delta) {
    qty = Math.max(1, qty + delta);
    document.getElementById('qtyDisplay').textContent = qty;
    
    // Sync the quantity with the main Add to Cart button
    const btn = document.querySelector('.js-add-cart');
    if (btn) btn.setAttribute('data-qty', qty);
  }

  function swapImage(btn, src) {
    document.getElementById('mainImage').src = src;
    document.querySelectorAll('[onclick^="swapImage"]').forEach(b => b.classList.remove('thumbnail-active'));
    btn.classList.add('thumbnail-active');
  }
</script>