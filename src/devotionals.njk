---
layout: base.njk
title: Devotionals
permalink: /devotionals/index.html
activeNav: devotionals
---
{% import "macros.njk" as macros %}

<section class="relative mb-20 text-center max-w-7xl mx-auto px-6 pt-8">
  <div class="absolute -top-12 -left-8 scrapbook-rotate-neg-1 hidden lg:block">
    <div class="bg-secondary-container px-6 py-2 rounded-none shadow-sm scrapbook-rotate-neg-1 border-b-4 border-on-secondary-container/10">
      <span class="font-headline font-black text-on-secondary-container text-sm uppercase tracking-widest italic">New Arrival ✨</span>
    </div>
  </div>
  <h1 class="font-headline text-6xl md:text-8xl font-black text-primary tracking-tighter mb-6 relative z-10">
    Devotionals <br/>
    <span class="text-on-primary-container bg-primary-container px-4 py-1 rounded-xl scrapbook-rotate-1 inline-block">Collection</span>
  </h1>
  <p class="text-xl text-on-surface-variant max-w-2xl mx-auto mb-12">
    Quiet your soul and find your creative flow with reflective journals and prayer prompts.
  </p>
  <div class="grid grid-cols-12 gap-6 h-[320px] md:h-[500px] mb-12 max-w-6xl mx-auto">
    <div class="col-span-12 md:col-span-8 relative overflow-hidden rounded-xl scrapbook-rotate-neg-1 shadow-xl h-full min-h-[200px]">
      <img class="w-full h-full object-cover" alt="" src="/static/img/pages/devo-hero-main.webp" width="900" height="600" loading="lazy" decoding="async"/>
    </div>
    <div class="col-span-12 md:col-span-4 flex flex-row md:flex-col gap-4 md:gap-6 h-auto md:h-full">
      <div class="flex-1 md:h-1/2 relative overflow-hidden rounded-xl scrapbook-rotate-1 shadow-lg min-h-[140px]">
        <img class="w-full h-full object-cover" alt="" src="/static/img/pages/devo-hero-side1.webp" width="400" height="280" loading="lazy" decoding="async"/>
      </div>
      <div class="flex-1 md:h-1/2 relative overflow-hidden rounded-xl scrapbook-rotate-neg-1 shadow-lg min-h-[140px]">
        <img class="w-full h-full object-cover" alt="" src="/static/img/pages/devo-hero-side2.webp" width="400" height="280" loading="lazy" decoding="async"/>
      </div>
    </div>
  </div>
</section>

<section class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-16 relative pb-8">


  {% for p in products | devotionalProducts %}
    {% set idx = loop.index0 %}
    <a href="/product/{{ p.slug }}/" class="block group cursor-pointer lg:pl-0">
      <div class="relative mb-6 rounded-xl bg-surface-container-low p-6 transition-transform duration-300 shadow-sm border border-outline-variant/20 h-full flex flex-col {% if idx == 0 %}group-hover:-translate-y-2{% elif idx == 1 %}group-hover:rotate-1{% elif idx == 2 %}group-hover:-rotate-1{% elif idx == 3 %}group-hover:scale-[1.02]{% else %}group-hover:-translate-y-2{% endif %}">
        {% if loop.first %}
        <article 
          class="js-prompt-sticky absolute -top-8 -left-4 w-5/6 scrapbook-rotate-2 z-30 pointer-events-none group-hover:scale-105 transition-transform"
          data-prompts='{{ devotionalsSettings.monthly_prompts | dump | escape }}'
          data-override-text="{{ devotionalsSettings.prompt_text | escape }}"
          data-override-title="{{ devotionalsSettings.prompt_title | escape }}"
        >
          <div class="bg-[#fff9c4] p-6 shadow-2xl border-t-8 border-yellow-200 relative">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 w-20 h-8 bg-secondary-container/60 washi-tape rotate-[-2deg]" aria-hidden="true"></div>
            <span class="material-symbols-outlined text-yellow-600 block mb-2">edit_note</span>
            <h3 class="font-headline font-bold text-on-surface text-sm mb-2">Prompt of the Month</h3>
            
            <p id="prompt-text-display" class="font-handwritten text-xl text-on-surface italic mb-4 leading-snug">
              {{ devotionalsSettings.prompt_text | default("Seek His presence in the quiet moments today.") }}
            </p>
            
            <div class="flex justify-end">
              <span id="prompt-title-display" class="text-[10px] uppercase font-black text-yellow-600/40">
                {{ devotionalsSettings.prompt_title | default("This season") }}
              </span>
            </div>
          </div>
        </article>

        <script>
          (function() {
            const container = document.querySelector('.js-prompt-sticky');
            if (!container) return;
            
            const overrideText = container.dataset.overrideText;
            const overrideTitle = container.dataset.overrideTitle;
            
            try {
              const prompts = JSON.parse(container.dataset.prompts || '[]');
              const now = new Date();
              const current = prompts[now.getMonth()];
              
              if (current) {
                const textEl = document.getElementById('prompt-text-display');
                const titleEl = document.getElementById('prompt-title-display');
                
                if (textEl && !overrideText) textEl.textContent = current.text;
                if (titleEl && !overrideTitle) titleEl.textContent = current.month + ' ' + now.getFullYear();
              }
            } catch (e) { console.warn("Auto-prompt error:", e); }
          })();
        </script>
        {% endif %}
        <div class="aspect-[3/4] overflow-hidden rounded-lg mb-6 bg-white/50">
          {% image p.image, p.title, "w-full h-full object-contain p-2", "400px" %}
        </div>
        {{ macros.smartBadge(p) }}
        <h3 class="font-headline text-2xl font-black text-primary mb-1">{{ p.title }}</h3>
        <p class="text-sm text-on-surface-variant mb-4 font-medium italic flex-grow">{{ p.subtitle }}</p>
        <div class="flex justify-between items-center mt-auto pt-4 w-full gap-3">
          {{ macros.priceDisplay(p, "text-xl") }}
          <button
            type="button"
            class="js-add-cart bg-primary text-on-primary px-5 py-2 rounded-full font-headline text-sm font-bold shadow-md hover:scale-105 active:scale-95 transition-all{% if p.stock_status == 'out_of_stock' %} opacity-50 pointer-events-none{% endif %}"
            data-slug="{{ p.slug }}"
            data-title="{{ p.title | escape }}"
            data-price="{{ p.price }}"
            data-image="{{ p.image | escape }}"
            data-subtitle="{{ p.subtitle | escape }}"
            data-preorder="{% if p.stock_status == 'pre_order' %}true{% else %}false{% endif %}"
            {% if p.stock_status == "out_of_stock" %}disabled{% endif %}
          >Add to Cart</button>
        </div>
      </div>
    </div>
    </a>

    {% if loop.index == 4 %}
      <div class="relative bg-tertiary-container/30 p-10 rounded-xl flex flex-col items-center justify-center text-center overflow-hidden scrapbook-rotate-1 md:col-span-2 lg:col-span-1 border-2 border-dashed border-tertiary">
        <span class="material-symbols-outlined text-4xl text-tertiary mb-4">auto_awesome</span>
        <h3 class="font-headline text-3xl font-black text-on-tertiary-container mb-4">{{ devotionalsSettings.bundle_title | default("Bundle & Save!") }}</h3>
        <p class="text-on-tertiary-container/80 mb-8 font-medium">{{ devotionalsSettings.bundle_description | default("Grab any 3 devotionals and get a free sticker sheet of your choice.") }}</p>
        <a href="{{ devotionalsSettings.bundle_cta_link | default('/checkout/') }}" class="bg-primary-dim text-on-primary px-8 py-3 rounded-full font-headline font-black uppercase tracking-widest text-sm shadow-xl hover:scale-110 transition-transform inline-block">{{ devotionalsSettings.bundle_cta_text | default("Get the Bundle") }}</a>
      </div>
    {% endif %}
  {% endfor %}
</section>

<section class="mt-24 mb-12 px-6 max-w-7xl mx-auto relative">
  <div class="bg-surface-container-low rounded-xl p-12 md:p-20 relative overflow-hidden flex flex-col md:flex-row items-center gap-12 shadow-sm border border-outline-variant/10">
    <div class="flex-1 z-10">
      <h2 class="font-headline text-4xl md:text-5xl font-black text-primary mb-6 leading-tight">Join our creative <br/>prayer community</h2>
      <p class="text-lg text-on-surface-variant mb-8">Get weekly prompts, free phone wallpapers, and early access to new journal drops.</p>
      <form id="community-form" class="flex flex-col sm:flex-row gap-4" action="/contact/" method="GET" autocomplete="off">
        <input name="subject" type="hidden" value="Prayer Community"/>
        <input name="message" type="hidden" value="I&apos;m falling in love with this creative community! ✨ I&apos;d be so honored to join the prayer circle. Please count me in for all the prompts and inspiration!"/>
        <input id="community-email" class="flex-1 px-6 py-4 rounded-full border-none bg-surface-container-high text-on-surface focus:ring-2 focus:ring-primary-container transition-all" placeholder="your-email@creative.com" type="email" required name="email" autocomplete="new-password"/>
        <button type="submit" class="bg-primary-dim text-on-primary px-10 py-4 rounded-full font-headline font-black uppercase tracking-widest text-sm shadow-xl hover:scale-105 transition-all text-center inline-flex items-center justify-center border-none cursor-pointer">Join with Love ✨</button>
      </form>
      <p class="text-xs text-on-surface-variant/70 mt-3 italic">You&apos;ll be redirected to our contact page to finalize your join! ✨</p>
    </div>
    <div class="flex-1 relative w-full">
      <div class="scrapbook-rotate-neg-1 relative z-10 shadow-2xl rounded-xl overflow-hidden max-w-lg mx-auto">
        {% image devotionalsSettings.community_image, "Community with journals", "w-full h-64 md:h-96 object-cover", "600px" %}
      </div>
      <div class="absolute -top-6 -right-2 md:right-6 w-24 h-24 bg-primary-container rounded-full flex items-center justify-center scrapbook-rotate-2 shadow-lg">
        <span class="text-4xl" aria-hidden="true">✨</span>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    const form = document.getElementById('community-form');
    const emailField = document.getElementById('community-email');
    
    if (form && emailField) {
      // Create error message element once
      const errorMsg = document.createElement('div');
      errorMsg.className = 'text-error text-xs font-bold mt-1 ml-4 opacity-0 transition-all flex items-center gap-1';
      errorMsg.innerHTML = '<span class="material-symbols-outlined text-sm">warning</span> Full email is needed! ✨';
      emailField.parentNode.parentNode.insertBefore(errorMsg, emailField.parentNode.nextSibling);

      form.addEventListener('submit', function(e) {
        const emailVal = emailField.value.trim();
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        
        if (!emailVal || !emailRegex.test(emailVal)) {
          e.preventDefault();
          
          // Visual Feedback
          emailField.classList.add('ring-2', 'ring-error', 'pulse-effect');
          errorMsg.classList.replace('opacity-0', 'opacity-100');
          emailField.focus();
          
          // Shake effect
          form.classList.add('animate-shake');
          
          setTimeout(() => {
            emailField.classList.remove('pulse-effect');
            form.classList.remove('animate-shake');
          }, 800);
        }
      });

      // Clear error on input
      emailField.addEventListener('input', () => {
        emailField.classList.remove('ring-2', 'ring-error', 'pulse-effect');
        errorMsg.classList.replace('opacity-100', 'opacity-0');
      });
    }
  })();
</script>

<style>
  @keyframes shake {
    0%, 100% { transform: translateY(0); }
    25% { transform: translateY(-4px); }
    75% { transform: translateY(4px); }
  }
  .animate-shake {
    animation: shake 0.1s ease-in-out 0s 3;
  }
  @keyframes pulse-red {
    0% { box-shadow: 0 0 0 0 rgba(176, 37, 0, 0.4); }
    70% { box-shadow: 0 0 0 10px rgba(176, 37, 0, 0); }
    100% { box-shadow: 0 0 0 0 rgba(176, 37, 0, 0); }
  }
  .pulse-effect {
    animation: pulse-red 1s infinite;
  }
  /* Prevent Autofill Blue Color */
  input:-webkit-autofill,
  input:-webkit-autofill:hover,
  input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0px 1000px #e3ddc5 inset !important;
    -webkit-text-fill-color: #312f23 !important;
    transition: background-color 5000s ease-in-out 0s;
  }
</style>
