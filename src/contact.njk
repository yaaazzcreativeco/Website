---
layout: base.njk
title: Contact Us
permalink: /contact/index.html
activeNav: contact
bodyClass: page-contact-dots
---
{% from "macros.njk" import messengerUrl %}

<div class="relative z-10 max-w-7xl mx-auto px-6 pt-8 pb-24">
  <header class="mb-16 text-center space-y-4">
    <h1 class="text-5xl md:text-7xl font-headline font-extrabold text-primary tracking-tighter leading-none">
      Let&apos;s stay in
      <span class="relative inline-block">
        touch!
        <span class="absolute -bottom-2 left-0 w-full h-4 bg-primary-container/40 -rotate-1 -z-10 rounded-sm"></span>
      </span>
    </h1>
    <p class="text-lg text-on-surface-variant max-w-2xl mx-auto italic">
      Have a question about your slam notebook? Or just want to say hi? We&apos;re all ears and full of sparkle!
    </p>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
    {% if contactSettings.contact_form_enabled != false %}
    <div class="lg:col-span-7 bg-surface-container-low p-8 md:p-12 rounded-xl shadow-[0_10px_30px_rgba(49,47,35,0.04)] rotate-1 relative">
      <div class="absolute -top-4 -right-4 bg-secondary-container shadow-[2px_2px_5px_rgba(0,0,0,0.05)] px-8 py-2 text-on-secondary-container font-headline font-bold -rotate-12 z-20 rounded-sm">
        Snail Mail? No, Digital!
      </div>
      <!-- FormSubmit: first time, open the activation link they email you for this address. AJAX errors often mean the form is not activated yet. -->
      <form name="contact" action="https://formsubmit.co/ajax/yaaazz.creativeco@gmail.com" method="POST" autocomplete="off" class="space-y-8" id="contact-form">
        <!-- FormSubmit Config -->
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_subject" id="dynamic-subject" value="Inquiry" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_replyto" id="contact-replyto" value="" />
        
        <!-- Honeypot -->
        <input type="text" name="_honey" style="display:none" autocomplete="off" />
        
        <div class="space-y-2">
          <label class="block text-sm font-bold text-on-surface-variant font-headline ml-1" for="c-name">What&apos;s your name?</label>
          <input class="w-full bg-surface-container-highest border-none rounded-full px-6 py-4 focus:ring-2 focus:ring-primary-container text-on-surface placeholder:text-on-surface-variant/40 transition-all font-body" id="c-name" name="name" type="text" placeholder="e.g. Creative Soul" autocomplete="new-password" required/>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="space-y-2">
            <label class="block text-sm font-bold text-on-surface-variant font-headline ml-1" for="c-email">Where can we reach you? (Email)</label>
            <input class="w-full bg-surface-container-highest border-none rounded-full px-6 py-4 focus:ring-2 focus:ring-primary-container text-on-surface placeholder:text-on-surface-variant/40 transition-all font-body" id="c-email" name="email" type="email" placeholder="hello@yourworld.com" autocomplete="new-password" required/>
          </div>
          <div class="space-y-2">
            <label class="block text-sm font-bold text-on-surface-variant font-headline ml-1" for="c-phone">Phone number</label>
            <input class="w-full bg-surface-container-highest border-none rounded-full px-6 py-4 focus:ring-2 focus:ring-primary-container text-on-surface placeholder:text-on-surface-variant/40 transition-all font-body" id="c-phone" name="phone" type="tel" placeholder="09XX-XXX-XXXX" autocomplete="new-password" required inputmode="numeric" pattern="[0-9+\-\s]+"/>
          </div>
        </div>
        <div class="space-y-2">
          <label class="block text-sm font-bold text-on-surface-variant font-headline ml-1" for="c-msg">Spill the tea (Your Message)</label>
          <textarea class="w-full bg-surface-container-highest border-none rounded-xl px-6 py-4 focus:ring-2 focus:ring-primary-container text-on-surface placeholder:text-on-surface-variant/40 transition-all resize-none font-body" id="c-msg" name="message" rows="5" placeholder="Write your heart out here…" autocomplete="new-password" required></textarea>
        </div>
        <button class="w-full bg-gradient-to-r from-primary to-primary-dim text-on-primary font-headline font-extrabold text-xl py-5 rounded-full shadow-lg hover:scale-[1.02] active:scale-95 transition-all duration-200 flex items-center justify-center gap-3" type="submit">
          Send some magic
          <span class="material-symbols-outlined">auto_awesome</span>
        </button>
      </form>
    </div>
    {% endif %}

    <div class="lg:col-span-5 space-y-10">
      <section id="bulk-quote" class="bg-tertiary-container/30 p-8 rounded-lg -rotate-1 relative overflow-hidden group">
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-tertiary-container/50 rounded-full blur-3xl group-hover:scale-150 transition-transform"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-4">
            <div class="bg-tertiary text-on-tertiary w-10 h-10 rounded-full flex items-center justify-center shadow-md">
              <span class="material-symbols-outlined">groups</span>
            </div>
            <h2 class="text-2xl font-headline font-bold text-on-tertiary-container">Bulk Orders</h2>
          </div>
          <p class="text-on-tertiary-container/80 mb-6 italic">
            Planning a school event or a creative workshop? We love helping communities grow. Get special rates for 20+ journals!
          </p>
          <form id="bulk-order-form" name="bulk_order" action="https://formsubmit.co/ajax/yaaazz.creativeco@gmail.com" method="POST" autocomplete="off" class="space-y-4 text-left">
            <!-- FormSubmit Config -->
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_subject" value="Bulk Order Request" />
            <input type="hidden" name="_template" value="table" />
            
            <!-- Honeypot -->
            <input type="text" name="_honey" style="display:none" autocomplete="off" />

            <div>
              <label class="block text-xs font-bold text-on-tertiary-container/90 mb-1" for="bulk-org">Organization / school</label>
              <input class="bulk-input w-full bg-white border-none rounded-full px-4 py-3 text-on-surface text-sm transition-all focus:ring-2 focus:ring-tertiary-fixed font-body" id="bulk-org" name="organization" required placeholder="Organization name" autocomplete="new-password"/>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-bold text-on-tertiary-container/90 mb-1" for="bulk-name">Contact name</label>
                <input class="bulk-input w-full bg-white border-none rounded-full px-4 py-3 text-on-surface text-sm transition-all focus:ring-2 focus:ring-tertiary-fixed font-body" id="bulk-name" name="name" required placeholder="Jane Doe" autocomplete="new-password"/>
              </div>
              <div>
                <label class="block text-xs font-bold text-on-tertiary-container/90 mb-1" for="bulk-phone">Contact number</label>
                <input class="bulk-input w-full bg-white border-none rounded-full px-4 py-3 text-on-surface text-sm transition-all focus:ring-2 focus:ring-tertiary-fixed font-body" id="bulk-phone" name="phone" type="tel" required placeholder="09XX-XXX-XXXX" autocomplete="new-password" inputmode="numeric" pattern="[0-9+\-\s]+"/>
              </div>
            </div>
            <div>
              <label class="block text-xs font-bold text-on-tertiary-container/90 mb-1" for="bulk-qty">Item & Estimated Quantity</label>
              <div class="relative group/qty">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-tertiary/60 transition-colors group-focus-within/qty:text-tertiary pointer-events-none z-10">shopping_bag</span>
                <input class="bulk-input w-full bg-white border-none rounded-full pl-12 pr-4 py-3 text-on-surface text-sm transition-all focus:ring-2 focus:ring-tertiary-fixed font-body" id="bulk-qty" name="estimated_quantity" placeholder="e.g. 24 Starry Day Notebooks" required autocomplete="new-password"/>
              </div>
            </div>
            <div class="grid grid-cols-10 gap-3">
              <div class="col-span-7">
                <label class="block text-xs font-bold text-on-tertiary-container/90 mb-1" for="bulk-email">Contact email</label>
                <input class="bulk-input w-full bg-white border-none rounded-full px-4 py-3 text-on-surface text-sm transition-all focus:ring-2 focus:ring-tertiary-fixed font-body" id="bulk-email" name="email" type="email" required placeholder="contact@you.com" autocomplete="new-password"/>
              </div>
              <div class="col-span-3">
                <label class="block text-xs font-bold text-on-tertiary-container/90 mb-1" for="bulk-when">Needed by</label>
                <div class="relative group/date">
                  <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-tertiary/60 transition-colors group-focus-within/date:text-tertiary pointer-events-none z-10">calendar_today</span>
                  <input class="bulk-input w-full bg-white border-none rounded-full pl-12 pr-4 py-3 text-on-surface text-sm transition-all focus:ring-2 focus:ring-tertiary-fixed cursor-pointer font-body" id="bulk-when-display" readonly placeholder="Date ✨" required autocomplete="new-password"/>
                  <input class="absolute inset-0 opacity-0 cursor-pointer w-full h-full z-20" id="bulk-when" name="needed_by" type="date" required autocomplete="new-password"/>
                </div>
              </div>
            </div>
            <button type="submit" class="inline-flex items-center gap-2 font-headline font-extrabold text-tertiary hover:underline text-lg bg-transparent border-none cursor-pointer p-0 group/btn">
              Request a quote
              <span class="material-symbols-outlined text-sm group-hover/btn:translate-x-1 transition-transform">arrow_forward</span>
            </button>
          </form>
        </div>
      </section>

      <section class="space-y-6">
        <div class="flex items-center gap-2 px-2">
          <div class="h-0.5 flex-grow bg-outline-variant/20"></div>
          <span class="font-headline font-bold text-outline uppercase tracking-widest text-xs whitespace-nowrap">Find Us Everywhere</span>
          <div class="h-0.5 flex-grow bg-outline-variant/20"></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          {% if settings.instagram_url %}
          <a class="bg-surface-container-highest p-4 rounded-xl flex items-center gap-3 hover:bg-secondary-container transition-colors group" href="{{ settings.instagram_url }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <div class="bg-surface-container-lowest w-10 h-10 rounded-full flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-secondary">photo_camera</span>
            </div>
            <span class="font-headline font-bold text-on-surface-variant">Instagram</span>
          </a>
          {% endif %}

          {% if settings.tiktok_url %}
          <a class="bg-surface-container-highest p-4 rounded-xl flex items-center gap-3 hover:bg-tertiary-container transition-colors group" href="{{ settings.tiktok_url }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <div class="bg-surface-container-lowest w-10 h-10 rounded-full flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-tertiary">music_note</span>
            </div>
            <span class="font-headline font-bold text-on-surface-variant">TikTok</span>
          </a>
          {% endif %}

          {% if settings.facebook_url %}
          <a class="bg-surface-container-highest p-4 rounded-xl flex items-center gap-3 hover:bg-primary-container/50 transition-colors group" href="{{ settings.facebook_url }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <div class="bg-surface-container-lowest w-10 h-10 rounded-full flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-primary">thumb_up</span>
            </div>
            <span class="font-headline font-bold text-on-surface-variant">Facebook</span>
          </a>
          {% endif %}
          {% if settings.youtube_url %}
          <a class="bg-surface-container-highest p-4 rounded-xl flex items-center gap-3 hover:bg-error-container/30 transition-colors group" href="{{ settings.youtube_url }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
            <div class="bg-surface-container-lowest w-10 h-10 rounded-full flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-error">play_circle</span>
            </div>
            <span class="font-headline font-bold text-on-surface-variant">YouTube</span>
          </a>
          {% endif %}
          {% if settings.shopee_url %}
          <a class="bg-surface-container-highest p-4 rounded-xl flex items-center gap-3 hover:bg-orange-100 transition-colors group" href="{{ settings.shopee_url }}" target="_blank" rel="noopener noreferrer" aria-label="Shopee">
            <div class="bg-surface-container-lowest w-10 h-10 rounded-full flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-orange-600">shopping_bag</span>
            </div>
            <span class="font-headline font-bold text-on-surface-variant">Shopee</span>
          </a>
          {% endif %}
          {% if settings.lazada_url %}
          <a class="bg-surface-container-highest p-4 rounded-xl flex items-center gap-3 hover:bg-blue-100 transition-colors group" href="{{ settings.lazada_url }}" target="_blank" rel="noopener noreferrer" aria-label="Lazada">
            <div class="bg-surface-container-lowest w-10 h-10 rounded-full flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-blue-600">storefront</span>
            </div>
            <span class="font-headline font-bold text-on-surface-variant">Lazada</span>
          </a>
          {% endif %}
        </div>
      </section>

      <div class="relative pt-8">
        <div class="absolute top-4 left-4 bg-primary-container shadow-[2px_2px_5px_rgba(0,0,0,0.05)] px-6 py-1 text-on-primary-container font-headline font-bold rotate-3 z-20 text-sm rounded-sm">
          Our Studio Vibe
        </div>
        <div class="aspect-square bg-surface-container overflow-hidden rounded-xl -rotate-2 border-8 border-surface-container-lowest shadow-lg">
          {% if contactSettings.studio_photo %}
          {% image contactSettings.studio_photo, "Workspace with journals and stickers", "w-full h-full object-cover grayscale-[20%] hover:grayscale-0 transition-all duration-500" %}
          {% else %}
          <img
            class="w-full h-full object-cover grayscale-[20%] hover:grayscale-0 transition-all duration-500"
            alt="Workspace with journals and stickers"
            src="/static/img/pages/studio-photo.webp"
            width="600"
            height="600"
            loading="lazy"
          />
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.__formLoadTime = Date.now();

  (function() {
    // 1. Auto-populate from URL AND dynamic Subject
    const params = new URLSearchParams(window.location.search);
    const email = params.get('email');
    const messageParam = params.get('message');
    const subjectParam = params.get('subject');
    const returnMsgId = params.get('return_msg');

    const RETURN_REASON_PRESETS = {
      "1": "I'm starting a return: my item arrived damaged or defective.\n\nOrder / tracking (if any):\n\n",
      "2": "I'm requesting an exchange for a different product or variant.\n\nWhat I ordered vs what I need:\n\n",
      "3": "I'd like to return an unused item in original condition.\n\nReason:\n\n",
      "4": "My package never arrived. Please help with a lost parcel or reship.\n\nLast known tracking:\n\n",
      "5": "I received the wrong item and need a return or exchange.\n\nWhat I got vs what I ordered:\n\n"
    };

    if (subjectParam) {
      const subjectField = document.getElementById('dynamic-subject');
      if (subjectField) subjectField.value = subjectParam;
    }

    let messageBody = null;
    if (returnMsgId && RETURN_REASON_PRESETS[returnMsgId]) {
      messageBody = RETURN_REASON_PRESETS[returnMsgId];
    } else if (messageParam) {
      try {
        messageBody = decodeURIComponent(String(messageParam).replace(/\+/g, ' '));
      } catch (e) {
        messageBody = messageParam;
      }
    }

    if (email) {
      const emailField = document.getElementById('c-email');
      if (emailField) emailField.value = email;
    }

    if (messageBody) {
      const msgField = document.getElementById('c-msg');
      if (msgField) msgField.value = messageBody;
    }

    // 2. Magic Validation for Contact Form
    const form = document.getElementById('contact-form');
    if (form) {
      const requiredFields = form.querySelectorAll('[required]');
      
      form.addEventListener('submit', function(e) {
        let hasError = false;
        
        requiredFields.forEach(field => {
          const isEmail = field.type === 'email';
          const isPhone = field.id === 'c-phone';
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          const phoneRegex = /^[0-9+\-\s]+$/;
          const val = field.value.trim();
          
          let isValid = !!val;
          if (isValid && isEmail) isValid = emailRegex.test(val);
          if (isValid && isPhone) isValid = phoneRegex.test(val);

          if (!isValid) {
            hasError = true;
            field.classList.add('ring-2', 'ring-error', 'pulse-effect');
            
            let err = field.parentNode.querySelector('.magic-error');
            if (!err) {
              err = document.createElement('div');
              err.className = 'magic-error text-error text-[10px] font-bold mt-1 ml-4 transition-all flex items-center gap-1';
              field.parentNode.appendChild(err);
            }
            if (isPhone && val && !phoneRegex.test(val)) {
              err.innerHTML = `<span class="material-symbols-outlined text-[12px]">warning</span> Numbers only please! ✨`;
            } else if (isEmail && val && !emailRegex.test(val)) {
              err.innerHTML = `<span class="material-symbols-outlined text-[12px]">warning</span> That doesn't look like a real email! ✨`;
            } else {
              err.innerHTML = `<span class="material-symbols-outlined text-[12px]">warning</span> ${field.placeholder.split('.')[0] || 'This field'} is needed! ✨`;
            }
            
            if (hasError && field === requiredFields[0]) field.focus();
          }
        });

        const timeSinceLoad = Date.now() - window.__formLoadTime;
        const skipBotDelay = params.has('subject') || params.has('return_msg') || params.has('message') || params.has('email');
        if (!skipBotDelay && timeSinceLoad < 1200) {
            hasError = true;
            console.warn("Blocked bot submission due to typing speed.");
        }

        if (hasError) {
          e.preventDefault();
          form.classList.add('animate-shake');
          setTimeout(() => {
            form.classList.remove('animate-shake');
            requiredFields.forEach(f => f.classList.remove('pulse-effect'));
          }, 800);
        } else {
          e.preventDefault();
          const btn = form.querySelector('button[type="submit"]');
          const originalText = btn.innerHTML;
          btn.innerHTML = 'Sending magic... <span class="material-symbols-outlined animate-spin" style="animation: spin 1s linear infinite;">refresh</span>';
          btn.disabled = true;
          btn.style.opacity = '0.7';

          const outData = new FormData(form);
          const nameVal = outData.get('name') || 'Someone';
          const emailVal = outData.get('email') || '';
          const baseSubj = document.getElementById('dynamic-subject').value || 'Inquiry';
          const shortId = Math.random().toString(36).substring(2,6).toUpperCase();
          const dateStr = new Date().toLocaleDateString('en-US', {month: 'short', day: 'numeric'});
          outData.set('_subject', `${baseSubj} - ${nameVal} [${dateStr} #${shortId}]`);
          if (emailVal) {
            outData.set('_replyto', emailVal);
            const rt = document.getElementById('contact-replyto');
            if (rt) rt.value = emailVal;
          }

          fetch(form.action, {
            method: 'POST',
            body: outData,
            headers: { 'Accept': 'application/json' }
          })
          .then(async function (response) {
            const raw = await response.text();
            let data;
            try {
              data = JSON.parse(raw);
            } catch (e) {
              throw new Error(raw ? raw.slice(0, 280) : 'Invalid response from form service.');
            }
            if (!response.ok || data.success === false) {
              throw new Error(data.message || data.error || 'Form could not be sent.');
            }
            return data;
          })
          .then(function () {
            form.innerHTML = `
              <div class="text-center pt-16 pb-12 animate-fade-in">
                <div class="inline-flex items-center justify-center w-20 h-20 bg-primary-container rounded-full mb-6 relative">
                  <div class="absolute inset-0 bg-primary/20 rounded-full animate-ping"></div>
                  <span class="material-symbols-outlined text-primary text-4xl relative z-10">check_circle</span>
                </div>
                <h3 class="font-headline font-black text-3xl text-primary mb-3">Sprinkled with Magic!</h3>
                <p class="text-on-surface-variant text-lg">Your message is flying its way to us. We'll be in touch soon ✨</p>
              </div>`;
          })
          .catch(function (error) {
            var hint = (error && error.message) ? error.message : "Unknown error.";
            if (/activation|token|valid link/i.test(hint)) {
              hint += "\n\nIf you are the site owner: open FormSubmit’s email and activate this form for yaaazz.creativeco@gmail.com, or send a test from their dashboard.";
            }
            alert("We couldn’t send the form.\n\n" + hint);
            btn.innerHTML = originalText;
            btn.disabled = false;
            btn.style.opacity = '1';
          });
        }
      });

      requiredFields.forEach(field => {
        field.addEventListener('input', () => {
          field.classList.remove('ring-2', 'ring-error', 'pulse-effect');
          const err = field.parentNode.querySelector('.magic-error');
          if (err) err.remove();
        });
      });
    }

    // 3. Bulk Order Form Validation
    const bulkForm = document.getElementById('bulk-order-form');
    if (bulkForm) {
      const bulkRequired = bulkForm.querySelectorAll('[required]');
      bulkForm.addEventListener('submit', function(e) {
        let hasError = false;
        const phoneRegex = /^[0-9+\-\s]+$/;
        bulkRequired.forEach(field => {
          const isPhone = field.id === 'bulk-phone';
          const val = field.value.trim();
          if (!val) {
            hasError = true;
            field.classList.add('ring-2', 'ring-error', 'pulse-effect');
            if (hasError && field === bulkRequired[0]) field.focus();
          } else if (isPhone && !phoneRegex.test(val)) {
            hasError = true;
            field.classList.add('ring-2', 'ring-error', 'pulse-effect');
            let err = field.parentNode.querySelector('.bulk-error-msg');
            if (!err) {
              err = document.createElement('div');
              err.className = 'bulk-error-msg text-red-600 text-[10px] font-bold mt-1 ml-1';
              field.parentNode.appendChild(err);
            }
            err.innerHTML = `<span class="material-symbols-outlined text-[12px]">warning</span> Numbers only please!`;
            if (hasError && field === bulkRequired[0]) field.focus();
          }
        });

        if (hasError) {
          e.preventDefault();
          bulkForm.classList.add('animate-shake');
          setTimeout(() => {
            bulkForm.classList.remove('animate-shake');
            bulkRequired.forEach(f => f.classList.remove('pulse-effect'));
          }, 800);
        } else {
          e.preventDefault();
          const btn = bulkForm.querySelector('button[type="submit"]');
          const originalText = btn.innerHTML;
          btn.innerHTML = 'Sending... <span class="material-symbols-outlined animate-spin" style="animation: spin 1s linear infinite; font-size: 14px;">refresh</span>';
          btn.style.pointerEvents = 'none';
          
          const bulkData = new FormData(bulkForm);
          const orgVal = bulkData.get('organization') || 'Organization';
          const shortId = Math.random().toString(36).substring(2,6).toUpperCase();
          const dateStr = new Date().toLocaleDateString('en-US', {month: 'short', day: 'numeric'});
          bulkData.set('_subject', `Bulk Order - ${orgVal} [${dateStr} #${shortId}]`);

          fetch(bulkForm.action, {
            method: 'POST',
            body: bulkData,
            headers: { 'Accept': 'application/json' }
          })
          .then(async function (response) {
            const raw = await response.text();
            let data;
            try {
              data = JSON.parse(raw);
            } catch (e) {
              throw new Error(raw ? raw.slice(0, 280) : 'Invalid response from form service.');
            }
            if (!response.ok || data.success === false) {
              throw new Error(data.message || data.error || 'Form could not be sent.');
            }
            return data;
          })
          .then(function () {
            bulkForm.innerHTML = `
              <div class="text-center pt-12 pb-8 animate-fade-in bg-white/50 rounded-xl border border-tertiary/10">
                <div class="inline-flex items-center justify-center w-14 h-14 bg-tertiary-container rounded-full mb-4 shadow-inner">
                  <span class="material-symbols-outlined text-tertiary text-2xl">celebration</span>
                </div>
                <h3 class="font-headline font-black text-2xl text-tertiary mb-2">Request Sent!</h3>
                <p class="text-on-tertiary-container/80 text-sm px-4">We're reviewing your bulk order request and will email you with special rates shortly.</p>
              </div>`;
          })
          .catch(function (error) {
            var hint = (error && error.message) ? error.message : 'Unknown error.';
            alert("Could not send your bulk request.\n\n" + hint);
            btn.innerHTML = originalText;
            btn.style.pointerEvents = 'auto';
          });
        }
      });

      bulkRequired.forEach(field => {
        field.addEventListener('input', () => {
          field.classList.remove('ring-2', 'ring-error', 'pulse-effect');
          const err = field.parentNode.querySelector('.bulk-error-msg');
          if (err) err.remove();
        });
      });
    }

    // 4. Date Formatter for 'Needed by'
    const hiddenDate = document.getElementById('bulk-when');
    const displayDate = document.getElementById('bulk-when-display');
    
    if (hiddenDate && displayDate) {
      hiddenDate.addEventListener('change', function() {
        if (this.value) {
          const date = new Date(this.value);
          const options = { month: 'long', day: '2-digit', year: 'numeric' };
          const formatted = date.toLocaleDateString('en-US', options);
          displayDate.value = formatted;
          displayDate.classList.remove('ring-2', 'ring-error');
        }
      });
    }
  })();
</script>

