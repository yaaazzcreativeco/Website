<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  (function() {
    var carousel = document.getElementById('layouts-carousel');
    var dots = document.querySelectorAll('#carousel-dots button');
    if (carousel && dots.length === 3) {
      var activeDot = 0;

      function getPositions() {
        var maxScroll = carousel.scrollWidth - carousel.offsetWidth;
        var end = Math.max(0, maxScroll);
        return [0, end / 2, end];
      }

      function setActiveDot(index) {
        activeDot = index;
        dots.forEach(function(d, i) {
          if (i === index) {
            d.classList.remove('bg-primary/30', 'bg-primary/10');
            d.classList.add('bg-primary');
          } else if (i === 0) {
            d.classList.remove('bg-primary', 'bg-primary/10');
            d.classList.add('bg-primary/30');
          } else {
            d.classList.remove('bg-primary', 'bg-primary/30');
            d.classList.add('bg-primary/10');
          }
        });
      }

      dots.forEach(function(dot, index) {
        dot.addEventListener('click', function() {
          var positions = getPositions();
          carousel.scrollTo({ left: positions[index], behavior: 'smooth' });
          setActiveDot(index);
        });
      });

      var scrollTimeout;
      carousel.addEventListener('scroll', function() {
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(function() {
          var positions = getPositions();
          var scrollPos = carousel.scrollLeft;
          var closest = 0;
          var minDist = Math.abs(scrollPos - positions[0]);
          for (var i = 1; i < 3; i++) {
            var dist = Math.abs(scrollPos - positions[i]);
            if (dist < minDist) {
              minDist = dist;
              closest = i;
            }
          }
          if (closest !== activeDot) {
            setActiveDot(closest);
          }
        }, 100);
      });
    }
  })();
</script>
